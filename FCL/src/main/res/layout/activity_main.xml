<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:transitionName="background"
    android:background="@color/dark_bg"
    tools:context=".activity.MainActivity">

    <TextureView
        android:id="@+id/texture_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <VideoView
        android:id="@+id/video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- LEFT MENU - Vertical icon sidebar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/left_menu"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:background="@color/dark_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="100dp"
        android:paddingStart="5dp"
        android:paddingTop="10dp"
        android:paddingEnd="5dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- HOME -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_baseline_home_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- MANAGE -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/manage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_baseline_build_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/home" />

        <!-- DOWNLOAD -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_baseline_cloud_download_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/manage" />

        <!-- MULTIPLAYER/SERVERS -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/multiplayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_outline_account_tree_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/download" />

        <!-- PROFILE -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_baseline_person_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/multiplayer" />

        <!-- SETTINGS -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_baseline_settings_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profile" />

        <!-- BACK -->
        <com.tungsten.fcllibrary.component.view.FCLMenuView
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_baseline_arrow_back_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/setting" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CENTER MENU - 2x3 Grid with large yellow buttons -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/center_menu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@color/dark_bg"
        app:layout_constraintEnd_toStartOf="@id/right_menu"
        app:layout_constraintStart_toEndOf="@+id/left_menu">

        <!-- Grid Container -->
        <GridLayout
            android:id="@+id/menu_grid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:padding="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="0.5">

            <!-- HOME BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_home"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="10dp"
                android:text="@string/home"
                android:textSize="16sp"
                android:textColor="@color/dark_text"
                android:textStyle="bold"
                app:backgroundTint="@color/yellow_accent"
                app:icon="@drawable/ic_baseline_home_24"
                app:iconSize="48dp"
                app:iconGravity="top"
                app:cornerRadius="12dp" />

            <!-- MANAGE BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_manage"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="10dp"
                android:text="@string/manage"
                android:textSize="16sp"
                android:textColor="@color/dark_text"
                android:textStyle="bold"
                app:backgroundTint="@color/yellow_accent"
                app:icon="@drawable/ic_baseline_build_24"
                app:iconSize="48dp"
                app:iconGravity="top"
                app:cornerRadius="12dp" />

            <!-- DOWNLOAD BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="10dp"
                android:text="@string/download"
                android:textSize="16sp"
                android:textColor="@color/dark_text"
                android:textStyle="bold"
                app:backgroundTint="@color/yellow_accent"
                app:icon="@drawable/ic_baseline_cloud_download_24"
                app:iconSize="48dp"
                app:iconGravity="top"
                app:cornerRadius="12dp" />

            <!-- SERVERS BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_servers"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="10dp"
                android:text="@string/multiplayer"
                android:textSize="16sp"
                android:textColor="@color/dark_text"
                android:textStyle="bold"
                app:backgroundTint="@color/yellow_accent"
                app:icon="@drawable/ic_outline_account_tree_24"
                app:iconSize="48dp"
                app:iconGravity="top"
                app:cornerRadius="12dp" />

            <!-- PROFILE BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_profile"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="10dp"
                android:text="@string/profile"
                android:textSize="16sp"
                android:textColor="@color/dark_text"
                android:textStyle="bold"
                app:backgroundTint="@color/yellow_accent"
                app:icon="@drawable/ic_baseline_person_24"
                app:iconSize="48dp"
                app:iconGravity="top"
                app:cornerRadius="12dp" />

            <!-- SETTINGS BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="10dp"
                android:text="@string/settings"
                android:textSize="16sp"
                android:textColor="@color/dark_text"
                android:textStyle="bold"
                app:backgroundTint="@color/yellow_accent"
                app:icon="@drawable/ic_baseline_settings_24"
                app:iconSize="48dp"
                app:iconGravity="top"
                app:cornerRadius="12dp" />

        </GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT MENU - Account and Launch -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/right_menu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@color/dark_bg_secondary"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.25">

        <!-- ACCOUNT SECTION -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:focusable="true"
            app:layout_constraintBottom_toTopOf="@id/start"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.tungsten.fcllibrary.component.view.FCLImageView
                android:id="@+id/avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:elevation="50dp"
                android:focusable="true"
                android:stateListAnimator="@xml/anim_scale_large"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:text="@string/account_state_no_account"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/yellow_accent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/avatar" />

            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/account_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:text="@string/account_state_add"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/account_name" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- LAUNCH SECTION -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="5dp"
            android:stateListAnimator="@xml/anim_scale"
            app:layout_constraintBottom_toTopOf="@id/version"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/text_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launch"
                android:textStyle="bold"
                android:textColor="@color/yellow_accent"
                app:layout_constraintBottom_toTopOf="@id/version_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.tungsten.fcllibrary.component.view.FCLImageView
                android:id="@+id/icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.tungsten.fcllibrary.component.view.FCLTextView
                android:id="@+id/version_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="31dp"
                android:ellipsize="marquee"
                android:gravity="center"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:textColor="@color/text_secondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/icon"
                app:layout_constraintTop_toBottomOf="@id/text_start"
                tools:text="1.21.1-Forge" />

            <com.tungsten.fcllibrary.component.view.FCLProgressBar
                android:id="@+id/version_progress"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- MANAGE VERSION BUTTON - Yellow -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/version"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="8dp"
            android:stateListAnimator="@xml/anim_scale"
            android:text="@string/manage_version"
            android:textAllCaps="false"
            android:textColor="@color/dark_text"
            app:backgroundTint="@color/yellow_accent"
            app:autoSizeMaxTextSize="14sp"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/jar"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- JAR EXECUTE BUTTON - Yellow -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/jar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:stateListAnimator="@xml/anim_scale"
            android:text="@string/jar_execute"
            android:textAllCaps="false"
            android:textColor="@color/dark_text"
            app:backgroundTint="@color/yellow_accent"
            app:autoSizeMaxTextSize="14sp"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintStart_toEndOf="@id/version" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- DYNAMIC ISLAND / TITLE -->
    <com.tungsten.fcllibrary.component.view.FCLDynamicIsland
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
