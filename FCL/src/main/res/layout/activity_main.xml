<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:transitionName="background"
    android:background="@color/dark_bg"
    tools:context=".activity.MainActivity">

    <TextureView
        android:id="@+id/texture_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <VideoView
        android:id="@+id/video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- TOP RIGHT - Language Selector -->
    <Spinner
        android:id="@+id/language_spinner"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:background="@color/yellow_accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- LEFT MENU - Horizontal rows (Collapsible) -->
    <LinearLayout
        android:id="@+id/left_menu"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/dark_bg"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ROW 1: HOME | MANAGE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_margin="5dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/menu_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="🏠 Home"
                android:textSize="12sp"
                android:textColor="@color/dark_text"
                app:backgroundTint="@color/yellow_accent"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/menu_manage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="📋 Manage"
                android:textSize="12sp"
                android:textColor="@color/dark_text"
                app:backgroundTint="@color/yellow_accent"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- ROW 2: DOWNLOAD | SERVERS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_margin="5dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/menu_download"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="📥 Download"
                android:textSize="12sp"
                android:textColor="@color/dark_text"
                app:backgroundTint="@color/yellow_accent"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/menu_servers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="🖥️ Servers"
                android:textSize="12sp"
                android:textColor="@color/dark_text"
                app:backgroundTint="@color/yellow_accent"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- ROW 3: PROFILE | SETTINGS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_margin="5dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/menu_profile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="👤 Profile"
                android:textSize="12sp"
                android:textColor="@color/dark_text"
                app:backgroundTint="@color/yellow_accent"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/menu_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="⚙️ Settings"
                android:textSize="12sp"
                android:textColor="@color/dark_text"
                app:backgroundTint="@color/yellow_accent"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- HAMBURGER MENU BUTTON - Toggle left menu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/menu_toggle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:text="☰"
        android:textSize="20sp"
        android:textColor="@color/dark_text"
        android:padding="0dp"
        app:backgroundTint="@color/yellow_accent"
        app:cornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- CENTER - Launch Button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/center_launch"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/dark_bg"
        app:layout_constraintEnd_toStartOf="@id/right_menu"
        app:layout_constraintStart_toEndOf="@+id/left_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- LARGE LAUNCH BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_launch"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:text="PLAY"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/dark_text"
            app:backgroundTint="@color/yellow_accent"
            app:cornerRadius="100dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT MENU - Account and Launch -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/right_menu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@color/dark_bg_secondary"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="100dp"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.25">

        <!-- ACCOUNT SECTION -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:focusable="true"
            app:layout_constraintBottom_toTopOf="@id/start"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:elevation="50dp"
                android:background="@color/yellow_accent"
                android:scaleType="centerInside"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:text="Player"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/yellow_accent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/avatar" />

            <TextView
                android:id="@+id/account_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:text="Add Account"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/account_name" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- LAUNCH SECTION -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="3dp"
            app:layout_constraintBottom_toTopOf="@id/version"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/text_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Launch"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="@color/yellow_accent"
                app:layout_constraintBottom_toTopOf="@id/version_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@color/yellow_accent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/version_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="25dp"
                android:ellipsize="marquee"
                android:gravity="center"
                android:singleLine="true"
                android:text="1.21.1"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/icon"
                app:layout_constraintTop_toBottomOf="@id/text_start" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- MANAGE VERSION BUTTON - Yellow -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/version"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="6dp"
            android:text="Manage"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="@color/dark_text"
            app:backgroundTint="@color/yellow_accent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/jar"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- JAR EXECUTE BUTTON - Yellow -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/jar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="6dp"
            android:text="Play"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="@color/dark_text"
            app:backgroundTint="@color/yellow_accent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.08"
            app:layout_constraintStart_toEndOf="@id/version" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
